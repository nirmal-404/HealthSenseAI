{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0",
    "sourceMap": true,
    "types": ["node", "jest"],
    "declaration": false
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}