{
  "info": {
    "name": "Appointment Service - RabbitMQ Test APIs",
    "description": "Test collection for RabbitMQ message publishing in Appointment Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. RabbitMQ Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/test/rabbitmq-status",
          "host": [
            "{{base_url}}"
          ],
          "path": ["test", "rabbitmq-status"]
        },
        "description": "Check RabbitMQ Producer connection status"
      },
      "response": []
    },
    {
      "name": "2. Publish Appointment Booked",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"appointmentId\": \"64f1e9c2d5a8b3f2e1c9d4b5\",\n  \"patientId\": \"64f1e9c2d5a8b3f2e1c9d4a0\",\n  \"patientEmail\": \"patient@example.com\",\n  \"patientName\": \"John Doe\",\n  \"patientPhone\": \"+1234567890\",\n  \"doctorId\": \"64f1e9c2d5a8b3f2e1c9d4c1\",\n  \"doctorName\": \"Dr. Jane Smith\",\n  \"doctorEmail\": \"doctor@example.com\",\n  \"doctorPhone\": \"+0987654321\",\n  \"appointmentDate\": \"2024-04-20\",\n  \"appointmentTime\": \"14:30\",\n  \"reason\": \"General Checkup\",\n  \"status\": \"booked\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/test/publish-appointment-booked",
          "host": [
            "{{base_url}}"
          ],
          "path": ["test", "publish-appointment-booked"]
        },
        "description": "Publish appointment booked event to RabbitMQ"
      },
      "response": []
    },
    {
